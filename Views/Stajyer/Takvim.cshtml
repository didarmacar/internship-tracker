                            </td>
                            <td>
                                <div class="calendar-day">28</div>
                            </td>
                            <td>
                                <div class="calendar-day">29</div>
                            </td>
                            <td style="background: #fff3cd;">
                                <div class="calendar-day"><strong>30</strong></div>
                                <div class="calendar-event event-toplanti">Bugün</div>
